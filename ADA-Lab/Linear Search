#include<stdio.h>

int main() {
    int array[9] = {1,2,3,4,5,6,7,8,9};
    int size = 9;
    int target;
    int found = 0;

    printf("Enter the element to be found: ");
    scanf("%d", &target);

    for (int i = 0; i < size; i++) {
        if (target == array[i]) {
            printf("Found at position %d\n", i);
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Not in the array\n");
    }

    return 0;
}
