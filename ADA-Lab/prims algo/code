#include <stdio.h>

#define INF 999

int main()
{
    int n, cost[10][10];
    int visited[10] = {0};

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter cost matrix:\n");
    for(int i = 0; i < n; i++)
        for(int j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    visited[0] = 1;   // Start from vertex 1

    int edges = 0, mincost = 0;

    printf("\nEdges in MST:\n");

    while(edges < n - 1)
    {
        int min = INF, u = -1, v = -1;

        for(int i = 0; i < n; i++)
        {
            if(visited[i])
            {
                for(int j = 0; j < n; j++)
                {
                    if(!visited[j] && cost[i][j] < min)
                    {
                        min = cost[i][j];
                        u = i;
                        v = j;
                    }
                }
            }
        }

        printf("%d - %d = %d\n", u + 1, v + 1, min);

        visited[v] = 1;
        mincost += min;
        edges++;
    }

    printf("Minimum Cost = %d\n", mincost);

    return 0;
}
