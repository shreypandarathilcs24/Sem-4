#include <stdio.h>

#define MAX 10
#define INF 999

int parent[MAX];

int find(int v)
{
    while(parent[v])
        v = parent[v];
    return v;
}

int main()
{
    int n, cost[MAX][MAX];
    int mincost = 0, edges = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter cost matrix:\n");
    for(int i = 0; i < n; i++)
        for(int j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    printf("\nEdges in MST:\n");

    while(edges < n - 1)
    {
        int min = INF, u = 0, v = 0;

        for(int i = 0; i < n; i++)
            for(int j = 0; j < n; j++)
                if(cost[i][j] < min)
                {
                    min = cost[i][j];
                    u = i;
                    v = j;
                }

        int p = find(u);
        int q = find(v);

        if(p != q)
        {
            printf("%d - %d = %d\n", u + 1, v + 1, min);
            mincost += min;
            parent[q] = p;
            edges++;
        }

        cost[u][v] = cost[v][u] = INF;
    }

    printf("Minimum Cost = %d\n", mincost);

    return 0;
}
