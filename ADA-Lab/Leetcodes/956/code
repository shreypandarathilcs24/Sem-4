#include <stdlib.h>
#include <string.h>

int max(int a, int b) {
    return a > b ? a : b;
}

int tallestBillboard(int* rods, int rodsSize) {
    int sum = 0;
    for (int i = 0; i < rodsSize; i++) {
        sum += rods[i];
    }

    int *dp = (int *)malloc(sizeof(int) * (sum + 1));
    for (int i = 0; i <= sum; i++) dp[i] = -1;

    dp[0] = 0;

    for (int i = 0; i < rodsSize; i++) {
        int r = rods[i];
        int *temp = (int *)malloc(sizeof(int) * (sum + 1));
        memcpy(temp, dp, sizeof(int) * (sum + 1));

        for (int diff = 0; diff <= sum - r; diff++) {
            if (temp[diff] < 0) continue;

            // Add to taller side
            dp[diff + r] = max(dp[diff + r], temp[diff]);

            // Add to shorter side
            int newDiff = abs(diff - r);
            dp[newDiff] = max(dp[newDiff], temp[diff] + (diff < r ? diff : r));
        }

        free(temp);
    }

    int result = dp[0];
    free(dp);
    return result;
}
