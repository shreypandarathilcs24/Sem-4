#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int n;

int partition(int a[], int low, int high)
{
    int pivot, temp;
    pivot = a[low];

    int i = low;
    int j = high;

    while (i < j)
    {
        while (a[i] <= pivot)
            i++;

        while (a[j] > pivot)
            j--;

        if (i < j)
        {
            temp = a[i];
            a[i] = a[j];
            a[j] = temp;
        }
    }

    temp = a[low];
    a[low] = a[j];
    a[j] = temp;

    return j;
}

void quicksort(int a[], int low, int high)
{
    int j;

    if (low < high)
    {
        j = partition(a, low, high);

        quicksort(a, low, j - 1);
        quicksort(a, j + 1, high);
    }
}

void main()
{
    clock_t start, end;
    double time_taken;

    srand(time(NULL));

    printf("N\tTime Taken (seconds)\n");

    for (n = 10000; n <= 50000; n += 10000)
    {
        int a[n];

        for (int i = 0; i < n; i++)
        {
            a[i] = rand() % 10000;
        }

        start = clock();

        quicksort(a, 0, n - 1);

        end = clock();

        time_taken = (double)(end - start) / CLOCKS_PER_SEC;

        printf("%d\t%f\n", n, time_taken);
    }
}
