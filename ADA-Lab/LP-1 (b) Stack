#include <stdio.h>
#include <string.h>
#include <stdlib.h>

char* orderlyQueue(char* s, int k) {
    int n = strlen(s);

    if (k == 1) {
        char* best = strdup(s);

        for (int i = 1; i < n; i++) {
            char temp[1001];
            
            strcpy(temp, s + i);
            strncat(temp, s, i);

            if (strcmp(temp, best) < 0) {
                strcpy(best, temp);
            }
        }

        return best;
    } 
    else {
        char* res = strdup(s);

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                if (res[i] > res[j]) {
                    char t = res[i];
                    res[i] = res[j];
                    res[j] = t;
                }
            }
        }

        return res;
    }
}
